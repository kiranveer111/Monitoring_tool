# .env (backend)
PORT=3000
NODE_ENV=development

# MySQL Database Configuration
DB_HOST=<DB IP>
DB_USER=<DB Username>
DB_PASSWORD=<DB Passowrd>
DB_DATABASE=monitoring_tool

# JWT Authentication
JWT_SECRET=supersecretjwtkey_please_change_this_in_production_environment_for_security
JWT_EXPIRES_IN=1h

# Email Configuration (for Nodemailer)
# Use a real SMTP server for production, or Ethereal.email for testing
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_SECURE=false # true for 465, false for other ports (e.g., 587, 25)
EMAIL_USER=your_ethereal_email@ethereal.email # Get this from Ethereal.email or your actual SMTP provider
EMAIL_PASS=your_ethereal_password # Get this from Ethereal.email or your actual SMTP provider
EMAIL_FROM="Monitoring Tool <no-reply@example.com>"

# SNMP Configuration (for net-snmp)
# SNMP Trap Receiver Host: This should be the IP address of your SNMP trap receiver/manager.
# You might need a tool like snmptrapd (Linux) or Trap Receiver (Windows) to test this.
SNMP_RECEIVER_HOST=127.0.0.1
SNMP_COMMUNITY=public # SNMP community string

# Example OIDs (You might need to define these in your MIBs if using a custom trap receiver)
SNMP_API_DOWN_OID=.1.3.6.1.4.1.9999.1.1 # Custom OID for API down alert
SNMP_CERT_EXPIRY_OID=.1.3.6.1.4.1.9999.1.2 # Custom OID for Certificate expiry alert

# Default Alerting Recipients (can be overridden by user-specific settings later)
ALERTING_EMAIL_RECIPIENT=admin@example.com
